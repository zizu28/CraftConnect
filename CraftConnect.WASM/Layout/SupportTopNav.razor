@using CraftConnect.WASM.Services
@inject ThemeService ThemeService
@implements IDisposable
<header class="support-nav-header">
    <div class="support-nav-container">
        <a href="/" class="logo">
            <i class="logo-icon bi bi-tools"></i>
            <span>CraftConnect</span>
        </a>
        <div class="nav-links">
            <a href="/home">Home</a>
            <a href="/browse">Browse</a>
            <a href="/about">About Us</a>
            <a href="/contact">Contact</a>
        </div>
        <div class="nav-spacer"></div>
        <div class="auth-buttons">
            <!-- Theme Toggle -->
            <button class="icon-btn theme-toggle" style="border:none; margin-right:8px;" @onclick="ThemeService.ToggleTheme" title="Toggle Theme">
                <i class="bi @(ThemeService.CurrentTheme == "light" ? "bi-moon-fill" : "bi-sun-fill")"></i>
            </button>
            <a href="/login" class="btn btn-secondary">Log In</a>
            <a href="/signup" class="btn btn-primary">Sign Up</a>
            <a href="/profile" class="profile-link">
                <img src="https" alt="User Avatar" class="avatar-img"
                     onerror="this.style.backgroundColor='#F3F4F6'; this.style.color='#9CA3AF'; this.innerHTML='U';" />
            </a>
        </div>
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChangedHandler;
    }

    private void OnThemeChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
    }
}