@using CraftConnect.WASM.Services
@inject NavigationManager NavigationManager
@inject ThemeService ThemeService
@implements IDisposable

<header class="top-nav-header-history">
    <div class="nav-content-history">
        <div class="nav-left-history">
            <a href="/" class="logo-history">
                <i class="logo-icon-history bi bi-hourglass-split" style="font-size: 1.8rem;"></i>
                <span class="logo-text-history">CraftConnect</span>
            </a>
            <nav class="main-navigation-history">
                <a href="/explore" class="nav-link-history">Explore</a>
                <a href="/customer/project-history" class="nav-link-history active">My Projects</a>
                <a href="/customer/messages" class="nav-link-history">Messages</a>
                <a href="/customer/profile" class="nav-link-history">Profile</a>
            </nav>
        </div>

        <div class="nav-right-history">
            <button class="btn-post-project" @onclick="@(() => NavigationManager.NavigateTo("/customer/post-project"))">Post a Project</button>
            <!-- Theme Toggle -->
            <button class="icon-btn theme-toggle" style="border:none; margin-right:8px; margin-left:16px;" @onclick="ThemeService.ToggleTheme" title="Toggle Theme">
                <i class="bi @(ThemeService.CurrentTheme == "light" ? "bi-moon-fill" : "bi-sun-fill")"></i>
            </button>
            <button class="profile-btn-history">
                <span class="avatar-history">JD</span>
            </button>
        </div>

        <!-- Mobile Menu Button -->
        <button class="icon-btn-history mobile-menu-btn-history">
            <i class="bi bi-list"></i>
        </button>
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChangedHandler;
    }

    private void OnThemeChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
    }
}
