@using CraftConnect.WASM.Services
@inject NavigationManager NavigationManager
@inject ThemeService ThemeService
@implements IDisposable

<aside class="settings-sidebar">
    <div class="sidebar-top">
        <div class="user-profile">
            <div class="user-avatar">AS</div>
            <div class="user-info">
                <span class="user-name">Artisan Smith</span>
                <span class="user-email">artisan.smith@email.com</span>
            </div>
        </div>

        <nav class="nav-links">
            <NavLink href="/settings/profile" class="nav-item" Match="NavLinkMatch.All">
                <i class="bi bi-person-fill"></i>
                <span>Profile</span>
            </NavLink>
            <NavLink href="/settings/notifications" class="nav-item">
                <i class="bi bi-bell-fill"></i>
                <span>Notifications</span>
            </NavLink>
            <NavLink href="/settings/security" class="nav-item">
                <i class="bi bi-shield-lock-fill"></i>
                <span>Security</span>
            </NavLink>
        </nav>
    </div>

    <div class="sidebar-bottom">
        <div style="display:flex; justify-content:center; margin-bottom:1rem;">
            <!-- Theme Toggle -->
            <button class="theme-toggle" @onclick="ThemeService.ToggleTheme" title="Toggle Theme">
                <i class="bi @(ThemeService.CurrentTheme == "light" ? "bi-moon-fill" : "bi-sun-fill")"></i>
            </button>
        </div>
        <button class="logout-btn" @onclick="Logout">Logout</button>
    </div>
</aside>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChangedHandler;
    }

    private void OnThemeChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    private void Logout()
    {
        // Add logout logic here
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
    }
}