@using CraftConnect.WASM.Services
@inject ThemeService ThemeService
@implements IDisposable
<header class="settings-nav-header">
    <div class="nav-content">
        <!-- Logo -->
        <a href="/" class="logo">
            <i class="bi bi-tools" style="font-size: 1.5rem;"></i>
            <span>CraftConnect</span>
        </a>

        <!-- Right Side Actions -->
        <div class="nav-actions">
            <a href="/customer/dashboard" class="nav-link">Dashboard</a>
            <a href="/customer/messages" class="nav-link">Messages</a>
            <a href="/projects" class="nav-link">Projects</a>
            <a href="/settings" class="nav-link active">Settings</a>
            <!-- Theme Toggle -->
            <button class="icon-btn theme-toggle" style="border:none; margin-right:8px;" @onclick="ThemeService.ToggleTheme" title="Toggle Theme">
                <i class="bi @(ThemeService.CurrentTheme == "light" ? "bi-moon-fill" : "bi-sun-fill")"></i>
            </button>
            <button class="icon-btn">
                <i class="bi bi-bell-fill"></i>
            </button>
            <button class="avatar-btn">
                <!-- User initials or image -->
            </button>
        </div>
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChangedHandler;
    }

    private void OnThemeChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
    }
}