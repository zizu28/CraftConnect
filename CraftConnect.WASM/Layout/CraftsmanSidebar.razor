@using CraftConnect.WASM.ViewModels
@using CraftConnect.WASM.Services
@inject ThemeService ThemeService
@implements IDisposable
<nav class="sidebar-craftsman">
    <div class="sidebar-top">
        <div class="user-profile-sidebar">
            <img class="avatar" src="https://placehold.co/40x40/FDBA74/7C2D12?text=JS" alt="@User.Name" />
            <div class="user-info">
                <span class="user-name">@User.Name</span>
                <span class="user-email">@User.Email</span>
            </div>
        </div>

        <ul class="nav-links">
            <li>
                <a href="/customer/dashboard" class="nav-item">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li>
                <a href="/customer/project-history" class="nav-item">
                    <i class="bi bi-briefcase-fill"></i>
                    <span>Projects</span>
                </a>
            </li>
            <li>
                <a href="/customer/messages" class="nav-item active">
                    <i class="bi bi-chat-dots-fill"></i>
                    <span>Messages</span>
                </a>
            </li>
            <li>
                <a href="/find-craftmen" class="nav-item">
                    <i class="bi bi-search"></i>
                    <span>Find Craftsmen</span>
                </a>
            </li>
        </ul>
    </div>

    <div class="sidebar-bottom">
        <div style="display:flex; justify-content:center; margin-bottom: 1rem;">
            <!-- Theme Toggle -->
            <button class="theme-toggle" @onclick="ThemeService.ToggleTheme" title="Toggle Theme">
                <i class="bi @(ThemeService.CurrentTheme == "light" ? "bi-moon-fill" : "bi-sun-fill")"></i>
            </button>
        </div>
        <a href="/customer/" class="new-project-btn">New Project</a>
        <ul class="nav-links-bottom">
            <li>
                <a href="/settings" class="nav-item">
                    <i class="bi bi-gear-fill"></i>
                    <span>Settings</span>
                </a>
            </li>
            <li>
                <a href="/help" class="nav-item">
                    <i class="bi bi-question-circle-fill"></i>
                    <span>Help</span>
                </a>
            </li>
        </ul>
    </div>
</nav>

@code {
    [Parameter]
    public UserProfileVM User { get; set; } = new();

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChangedHandler;
    }

    private void OnThemeChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
    }
}
