@using CraftConnect.WASM.Services
@inject ThemeService ThemeService
@implements IDisposable
<header class="policy-nav-header">
    <div class="policy-nav-container">
        <a href="/" class="logo">
            <i class="logo-icon bi bi-tools"></i>
            <span>CraftConnect</span>
        </a>
        <div class="nav-spacer"></div>
        <!-- Theme Toggle -->
        <button class="icon-btn theme-toggle" style="border:none;" @onclick="ThemeService.ToggleTheme" title="Toggle Theme">
            <i class="bi @(ThemeService.CurrentTheme == "light" ? "bi-moon-fill" : "bi-sun-fill")"></i>
        </button>
        <!-- Add any nav links here if needed -->
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChangedHandler;
    }

    private void OnThemeChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
    }
}
