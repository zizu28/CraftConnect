@using CraftConnect.WASM.Services
@inject NavigationManager NavManager
@inject ThemeService ThemeService
@implements IDisposable

<header class="navbar-container customer-dashboard-nav">
    <div class="navbar-content">
        <a href="/" class="brand-logo">
            <img src="/images/craftconnect-logo.png" alt="CraftConnect Logo" />
            CraftConnect
        </a>

        @* This area is intentionally empty to push the user profile to the right *@
        <div class="navbar-spacer"></div>

        @* Right Side Profile and Controls *@
        <div class="user-actions">
            <!-- Theme Toggle -->
            <button class="theme-toggle" style="margin-right:8px;" @onclick="ThemeService.ToggleTheme" title="Toggle Theme">
                <i class="bi @(ThemeService.CurrentTheme == "light" ? "bi-moon-fill" : "bi-sun-fill")"></i>
            </button>

            <a href="/notifications" class="nav-icon-link">
                <i class="bi bi-bell"></i>
            </a>
            
            <a href="/profile" class="profile-avatar-link">
                <img src="/images/user-avatar.jpg" alt="User Avatar" class="profile-avatar" />
            </a>
            
            <button class="btn btn-primary btn-post-project" @onclick="@(() => NavManager.NavigateTo("/post-project"))">
                Post a Project
            </button>
        </div>
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChangedHandler;
    }

    private void OnThemeChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
    }
}